generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum UserRole {
  CUSTOMER
  ADMIN
  OPS
  DELIVERY
}

enum AddressLabel {
  HOME
  WORK
  OTHER
}

enum PaymentMethod {
  UPI
  CARD
  WALLET
}

enum OrderStatus {
  PLACED
  CONFIRMED
  PICKING
  PACKED
  OUT_FOR_DELIVERY
  DELIVERED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  phone        String?
  role         UserRole @default(CUSTOMER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  addresses Address[]
  orders    Order[]
}

model Category {
  id          String   @id
  name        String
  emoji       String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]
}

model Product {
  id             String   @id
  slug           String   @unique
  name           String
  brand          String
  categoryId     String
  price          Int
  compareAtPrice Int?
  rating         Float
  stock          Int
  eta            String
  unit           String
  tags           Json
  description    String
  imagePath      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category   Category @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]

  @@index([categoryId])
}

model Address {
  id        String       @id @default(cuid())
  userId    String
  label     AddressLabel
  title     String
  line1     String
  line2     String
  city      String
  eta       String
  isDefault Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user   User    @relation(fields: [userId], references: [id])
  orders Order[]

  @@index([userId])
}

model Order {
  id              String        @id @default(cuid())
  displayId       String        @unique
  userId          String
  addressId       String?
  total           Int
  paymentMethod   PaymentMethod
  status          OrderStatus
  etaMinutes      Int
  riderName       String?
  riderPhoneMasked String?
  riderVehicle    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  address Address? @relation(fields: [addressId], references: [id])
  items   OrderItem[]
  events  OrderEvent[]

  @@index([userId])
  @@index([addressId])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Int

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model OrderEvent {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
}
