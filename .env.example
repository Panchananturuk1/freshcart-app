# Database
DATABASE_URL="file:./dev.db"

# Google Maps API Key (required for location feature)
# Get your API key from: https://developers.google.com/maps/documentation/javascript/get-api-key
# Enable these APIs for your key:
# - Maps JavaScript API
# - Places API
# - Geocoding API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your_google_maps_api_key_here"

# Authentication Secret (generate a random string)
AUTH_SECRET="your_auth_secret_here"

# Postgres (for production deployment)
POSTGRES_PRISMA_URL=""
POSTGRES_URL_NON_POOLING=""
